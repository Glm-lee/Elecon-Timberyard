def check_stock_and_build_context(product_id=None):
    # simple DB lookup example
    db = SessionLocal()
    try:
        if product_id:
            p = db.query(Product).filter(Product.id == product_id).first()
            if not p:
                return f"Product not found"
            return f"Product {p.name}: price {p.price}, stock {p.stock_quantity}"
        return "No product context"
    finally:
        db.close()

