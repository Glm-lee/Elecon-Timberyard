import pytest
from fastapi.testclient import TestClient
from backend.app.main import app

client = TestClient(app)

def test_sessions_pagination_and_unread():
    # this is an integration style smoke test that endpoints respond
    res = client.get('/admin/sessions')
    assert res.status_code in (200, 401)
    # if not authenticated, ensure Unauthorized returned; else the payload contains pagination keys
    if res.status_code == 200:
        data = res.json()
        assert 'total' in data and 'sessions' in data

@pytest.mark.asyncio
async def test_list_messages_structure():
    res = client.get('/admin/sessions/1/messages')
    assert res.status_code in (200, 404, 401)
    if res.status_code == 200:
        data = res.json()
        assert 'messages' in data